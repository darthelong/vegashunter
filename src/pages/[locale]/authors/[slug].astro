---
/**
 * Author profile — /{locale}/authors/{slug}/
 *
 * Lists every review (across all locales) attributed to the author. Schema.org
 * Person JSON-LD per docs §12.
 */
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';

import BaseLayout from '@layouts/BaseLayout.astro';
import { allLocales, localeByCode, defaultLocale, SITE_URL, buildPath } from '@lib/locales';
import { withLocale } from '@lib/i18n';
import { allAuthors, requireAuthor, authorJsonLd } from '@lib/authors';
import { alternateHrefs } from '@lib/seo';

export const getStaticPaths: GetStaticPaths = async () => {
  const out: Array<{ params: { locale: string; slug: string } }> = [];
  for (const locale of allLocales()) {
    for (const author of allAuthors()) {
      out.push({ params: { locale: locale.code, slug: author.slug } });
    }
  }
  return out;
};

const { locale: localeCode, slug } = Astro.params;
const locale = localeByCode(String(localeCode)) ?? defaultLocale();
const t = withLocale(locale.code);
const author = requireAuthor(String(slug));

const alternates = alternateHrefs((l) => `/${l.code}/authors/${author.slug}/`);

// All reviews attributed to this author, in any locale
const reviews = (await getCollection('reviews'))
  .filter((r) => r.data.author === author.slug)
  .sort((a, b) => +b.data.published_at - +a.data.published_at);

const url = `${SITE_URL}/${locale.code}/authors/${author.slug}/`;
---
<BaseLayout
  locale={locale.code}
  title={`${author.name} — ${author.role} · ${t('meta.site_name')}`}
  description={author.bio.slice(0, 160)}
  canonical={url}
  alternates={alternates}
  jsonLd={[authorJsonLd(author)]}
>
  <article class="max-w-3xl mx-auto px-6 lg:px-10 py-16">

    <div class="flex items-center gap-4 mb-12">
      <hr class="flex-1" />
      <span class="department">VEGASHUNTER · EDITORIAL</span>
      <hr class="flex-1" />
    </div>

    <header class="grid md:grid-cols-[160px_1fr] gap-8 items-start">
      <img src={author.avatar} alt={`${author.name} portrait`}
           class="w-40 h-40 object-cover bg-twilight border border-hairline rounded-sm" />
      <div>
        <p class="font-mono uppercase tracking-mono-caps text-xs text-mute mb-2">{author.role}</p>
        <h1 class="font-display text-4xl md:text-5xl leading-tight text-bone">{author.name}</h1>
        <div class="rule with-tick max-w-md mt-6"></div>
        <p class="mt-6 font-editorial italic text-xl text-silver leading-relaxed whitespace-pre-line">
          {author.bio}
        </p>
        {author.same_as.length > 0 && (
          <ul class="mt-6 flex flex-wrap gap-x-4 gap-y-2 text-xs text-silver">
            {author.same_as.map((href) => (
              <li>
                <a href={href} target="_blank" rel="noopener noreferrer external"
                   class="underline-offset-2 hover:underline">{href.replace(/^https?:\/\//, '')}</a>
              </li>
            ))}
          </ul>
        )}
      </div>
    </header>

    <hr class="my-12" />

    <section>
      <h2 class="font-display text-3xl text-bone mb-6">Reviews by {author.name}</h2>
      {reviews.length === 0
        ? <p class="text-silver italic">No reviews published yet.</p>
        : (
          <ul class="divide-y divide-hairline">
            {reviews.map((r) => {
              const rl = allLocales().find((l) => l.code === r.data.locale);
              const href = rl ? `/${rl.code}/${rl.paths.reviews}/${r.data.slug}/` : '#';
              return (
                <li class="py-5 grid md:grid-cols-[1fr_auto_auto] gap-2 md:gap-6 items-baseline">
                  <a href={href} class="font-display text-xl text-bone hover:underline decoration-ribbon underline-offset-4">
                    {r.data.title}
                  </a>
                  <span class="font-mono uppercase tracking-mono-caps text-xs text-mute">
                    {r.data.locale}
                  </span>
                  <span class="font-mono font-bold text-bone tabular-nums">
                    {r.data.score.toFixed(1)}
                  </span>
                </li>
              );
            })}
          </ul>
        )}
    </section>
  </article>
</BaseLayout>
