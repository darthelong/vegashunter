---
export interface Crumb { name: string; href: string }
export interface Props { crumbs: Crumb[] }
const { crumbs } = Astro.props;
---
<nav aria-label="Breadcrumb" class="text-xs font-mono uppercase tracking-mono-caps text-mute">
  <ol class="flex flex-wrap items-center gap-2">
    {crumbs.map((c, i) => (
      <li class="flex items-center gap-2">
        {i > 0 && <span aria-hidden="true">·</span>}
        {i < crumbs.length - 1
          ? <a href={c.href} class="hover:text-bone">{c.name}</a>
          : <span class="text-silver" aria-current="page">{c.name}</span>}
      </li>
    ))}
  </ol>
</nav>
