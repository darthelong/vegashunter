# Cloudflare Pages — HTTP response headers
# https://developers.cloudflare.com/pages/configuration/headers/

# Global security headers
/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=(), browsing-topics=()

# Self-hosted fonts — long cache
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Brand assets — long cache
/brand/*
  Cache-Control: public, max-age=31536000, immutable

# Astro hashed assets — long cache
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Sitemap — force application/xml so browsers render the XML tree.
# (The global X-Content-Type-Options: nosniff prevents browsers from
# auto-detecting MIME, so we set it explicitly.)
/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=300, s-maxage=3600

# Sitemap stylesheet — applied by Firefox/Chrome to render the XML as HTML
# for human visitors. Bots ignore this and parse the XML directly.
/sitemap.xsl
  Content-Type: text/xsl; charset=utf-8
  Cache-Control: public, max-age=3600

# Keep robots.txt as text/plain explicitly for the same reason.
/robots.txt
  Content-Type: text/plain; charset=utf-8
