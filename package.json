  "description": "VegasHunter.pro — editorial directory of online casinos. Press Ledger v0.2 identity.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "predev":        "node scripts/build-blocked-countries.mjs && node scripts/build-locale-routing.mjs && node scripts/build-sitemap.mjs",
    "prebuild":      "node scripts/build-blocked-countries.mjs && node scripts/build-locale-routing.mjs && node scripts/build-sitemap.mjs",
    "dev":           "astro dev",
    "build":         "astro check && astro build",
    "preview":       "astro preview",
    "astro":         "astro",
    "typecheck":     "astro check",
    "format":        "prettier --write 'src/**/*.{astro,ts,tsx,md,mdx}'",
    "build:fonts":   "bash scripts/build-fonts.sh",
    "build:blocked": "node scripts/build-blocked-countries.mjs",
